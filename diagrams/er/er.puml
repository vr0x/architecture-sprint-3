@startuml
title ER-диаграмма уровня кода системы отопления

' Сущность "Пользователь"
entity "Пользователь" as User {
    + id: int [PK]
    --
    username: string
    password_hash: string
    email: string
}

' Сущность "Дом"
entity "Дом" as House {
    + id: int [PK]
    --
    address: string

}

' Связующая таблица "Пользователь-Дом"
entity "ПользовательДом" as UserHouse {
    + user_id: int [FK]
    + house_id: int [FK]

}

' Сущность "Тип устройства"
entity "Тип устройства" as DeviceType {
    + id: int [PK]
    --
    name: string
    description: string
}

' Сущность "Устройство"
entity "Устройство" as Device {
    + id: int [PK]
    --
    device_type_id: int [FK]
    house_id: int [FK]
    name: string
    status: string
    last_updated: datetime
}

' Сущность "Температура"
entity "Температура" as Temperature {
    + id: int [PK]
    --
    device_id: int [FK]
    target_value: float
    set_by_user_id: int [FK]
    set_at: datetime
}

' Сущность "Телеметрия"
entity "Телеметрия" as TelemetryData {
    + id: int [PK]
    --
    device_id: int [FK]
    metric_type: string
    value: float
    timestamp: datetime
}

' Связи между таблицами
User ||--o{ UserHouse 
House ||--o{ UserHouse 
House ||--o{ Device 
DeviceType ||--o{ Device 
Device ||--o{ Temperature 
Device ||--o{ TelemetryData 
User ||--o{ Temperature 

@enduml